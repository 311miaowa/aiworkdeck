# Backend Environment Variables Example
# Copy this file to .env.production and fill in your actual values

# Server
SERVER_PORT=9696

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=checkba
DB_USERNAME=checkba
DB_PASSWORD=checkba123

# External APIs
# Qichacha (Enterprise Data)
QICHACHA_KEY=your_qichacha_key
QICHACHA_SECRET=your_qichacha_secret

# Tushare (Stock Data)
TUSHARE_TOKEN=your_tushare_token

# ElevenLabs (Text to Speech)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# PKULaw (Legal Data via MCP)
PKULAW_TOKEN=your_pkulaw_token

# Bocha AI (Web Search)
BOCHA_API_KEY=your_bocha_api_key

# WPS (Document Editing)
WPS_APP_ID=your_wps_app_id
WPS_APP_SECRET=your_wps_app_secret

# AI Models
# OpenRouter
OPENROUTER_API_KEY=your_openrouter_key

# Google Gemini
GEMINI_API_KEY=your_gemini_key

# Aliyun OSS & OCR
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
