{
  "name": "aiworkdeck-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "AI Workdeck desktop shell (Electron)",
  "author": "AI Workdeck contributors",
  "main": "main/main.js",
  "scripts": {
    "clean": "node scripts/clean.js",
    "dev": "cross-env AIWORKDECK_DESKTOP_DEV=1 electron .",
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.aiworkdeck.desktop",
    "productName": "AI Workdeck",
    "directories": {
      "output": "release"
    },
    "files": [
      "main/**",
      "preload/**"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist/build/h5",
        "to": "frontend/dist/build/h5"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    }
  }
}