# banana-slides 配置文件
# 复制此文件并配置您的 API Key

# AI 服务提供商配置 (选择一个)
# 格式: google | openai
AI_PROVIDER_FORMAT=google

# Google Gemini / Imagen API (推荐 - 与主项目共用)
# 从主项目的 application.yml 获取或使用相同的 API Key
GOOGLE_API_KEY=AIzaSyDpX0_tGBV2MCk-6PTh32whDFEBTgRLUCc
GOOGLE_API_BASE=https://generativelanguage.googleapis.com/v1beta

# 或者使用 OpenAI 兼容 API
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_API_BASE=https://api.openai.com/v1

# 服务端口
PORT=5000

# CORS 配置 (允许来自主项目后端的请求)
CORS_ORIGINS=*

# 日志级别
LOG_LEVEL=INFO

# 输出语言: zh(中文), en(英文), ja(日语), auto(自动)
OUTPUT_LANGUAGE=auto

# Docker 标识
IN_DOCKER=1

# 并发配置
MAX_DESCRIPTION_WORKERS=8
MAX_IMAGE_WORKERS=8

# MinerU 文件解析服务配置
# 本地 MinerU 服务（优先使用，无需 token）
MINERU_LOCAL_URL=http://mineru-service:8000
# 云服务配置（本地服务不可用时使用）
MINERU_TOKEN=eyJ0eXBlIjoiSldUIiwiYWxnIjoiSFM1MTIifQ.eyJqdGkiOiI0OTAwMDA2OCIsInJvbCI6IlJPTEVfUkVHSVNURVIiLCJpc3MiOiJPcGVuWExhYiIsImlhdCI6MTc2NzMzNTY5NiwiY2xpZW50SWQiOiJsa3pkeDU3bnZ5MjJqa3BxOXgydyIsInBob25lIjoiMTg2MTAyMTE1OTAiLCJvcGVuSWQiOm51bGwsInV1aWQiOiI3MGU1OWExZi05MDk4LTQ3YWUtOWM5My00NjJmNDM4YWM1MTUiLCJlbWFpbCI6IiIsImV4cCI6MTc2ODU0NTI5Nn0.HBsvy6piUgB0z8JuedrDBHZYN0kFNrl6L1V3LFIG4NgEQL6yU7xbTTzGL3sDtmUwIuV7eBZr1GddEQUVInuRAw
MINERU_API_BASE=https://mineru.net

# 是否强制使用云端 MinerU（跳过本地服务优先逻辑）
# 取值：1/true/yes/on 表示启用
MINERU_FORCE_CLOUD=1

